      "credentials": {
        "gmailOAuth2": {
          "id": "JWCH0xJsQby0CZJX",
          "name": "Gmail account 4"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"message\": \"Task added to Google Calendar. Reminder email will be sent 1 day before the deadline.\",\n  \"taskName\": \"{{ $('Parse & Validate Task').item.json.taskName }}\",\n  \"deadline\": \"{{ $('Parse & Validate Task').item.json.deadlineDate }}\",\n  \"calendarEventId\": \"{{ $('Create Google Calendar Event').item.json.id }}\",\n  \"reminderScheduledAt\": \"{{ $('Parse & Validate Task').item.json.reminderAt }}\",\n  \"notifyEmail\": \"{{ $('Parse & Validate Task').item.json.email }}\"\n}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "472d967e-6ed3-4a79-8bb6-bd141a69c9bd",
